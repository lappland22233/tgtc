# ==========================================
# 数据库配置 (PostgreSQL)
# ==========================================
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=file_distribution
# DB_SYNCHRONIZE — 开发环境设为 true 自动同步表结构，生产环境必须设为 false
DB_SYNCHRONIZE=true
# DB_MIGRATIONS_RUN — 启动时自动执行待处理迁移（生产环境推荐使用）
DB_MIGRATIONS_RUN=false

# ==========================================
# JWT 认证配置
# ==========================================
# 生产环境务必使用随机生成的强密钥
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# ==========================================
# Telegram Bot 配置（文件存储后端）
# ==========================================
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id
# TELEGRAM_API_BASE — Telegram API 基础地址，留空默认为 https://api.telegram.org
# 自建 API 代理（如 telegram-bot-api）可设为此地址以绕过官方频率限制
# TELEGRAM_API_BASE=http://localhost:8081

# ==========================================
# SMTP 邮件配置
# ==========================================
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-email-password
SMTP_FROM=noreply@example.com

# ==========================================
# 应用配置
# ==========================================
NODE_ENV=development
APP_HOST=0.0.0.0
APP_PORT=3000
# APP_URL — 应用完整公开地址，用于生成分享链接和密码页表单 action
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173
# CORS_ORIGINS — 逗号分隔的 CORS 允许来源（优先级高于 FRONTEND_URL）
CORS_ORIGINS=http://localhost:5173

# ==========================================
# 文件上传配置
# ==========================================
# 最大文件大小（字节），默认 20971520 = 20MB
MAX_FILE_SIZE=20971520
# 文件类型过滤模式：blacklist（黑名单）或 whitelist（白名单），默认 blacklist
# FILE_TYPE_MODE=blacklist
# 文件类型过滤列表，逗号分隔的扩展名，如 .zip,.exe,.sh。空值 = 不限制
# FILE_TYPE_FILTER=
